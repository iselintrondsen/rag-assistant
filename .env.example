# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Hent din API-nøkkel på: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Lokal/egen PostgreSQL:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_assistant
DB_USER=postgres
DB_PASSWORD=ditt_passord

# Alternativ: én connection string (f.eks. Railway)
# DATABASE_URL overstyrer DB_* hvis den er satt.
DATABASE_URL=

# Valgfritt: sett til "true" eller "require" hvis leverandøren krever SSL
DB_SSL=

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000

# Hvilken OpenAI-modell som brukes til chat
CHAT_MODEL=

# ─── Autentisering ────────────────────────────────────────────────────────────
# Sett et passord for å beskytte appen med enkel innlogging.
# La feltet stå tomt for å deaktivere autentisering (anbefalt lokalt).
ACCESS_PASSWORD=

# Valgfritt: separat admin-passord for opplasting/sletting/listing av dokumenter.
# Når satt, får brukere uten admin-innlogging kun chat-tilgang.
# Gå til /admin/login etter vanlig innlogging for å aktivere admin-cookie.
ADMIN_PASSWORD=

# Valgfritt, men anbefalt: hemmelig nøkkel for signering av auth-cookies.
# Bruk en lang tilfeldig streng i produksjon.
AUTH_COOKIE_SECRET=

# ─── Feilsporing (Sentry) ─────────────────────────────────────────────────────
# Hent din DSN på https://sentry.io etter å ha opprettet et Node.js-prosjekt.
# La feltet stå tomt for å deaktivere (anbefalt lokalt).
SENTRY_DSN=
